[user]
	name = Kenny Younger
	email = kyounger@gmail.com
	signingkey = 78F655479034FC9A

[merge]
	tool = Kaleidoscope

[mergetool "splice"]
    cmd = "mvim -f $BASE $LOCAL $REMOTE $MERGED -c 'SpliceInit'"
    trustExitCode = true

[core]
	excludesfile = /Users/kyounger/.config/git/.gitignore_global
	hooksPath = /Users/kyounger/.dotfiles/git/git-global-hooks
	pager = diff-so-fancy | less --tabs=4 -RFX
[color]
	ui = true

[branch]
        autosetuprebase = always
        autosetupmerge = always
[diff]
	indentHeuristic = true
[difftool]
	prompt = false
[mergetool "Kaleidoscope"]
	cmd = ksdiff --merge --output \"$MERGED\" --base \"$BASE\" -- \"$LOCAL\" --snapshot \"$REMOTE\" --snapshot
	trustExitCode = true
[mergetool]
	prompt = false
[hub]
        protocol = https
[push]
	default = current
	followTags = true
[pull]
        rebase = true
[credential]
	helper = osxkeychain
	usehttppath = false
[url "https://"]
	insteadOf = git://
[fetch]
	prune = true
[alias]
	add-no-white=!sh -c 'git diff -U0 -w --no-color "$@" | git apply --cached --ignore-whitespace --unidiff-zero -'
[color "diff-highlight"]
	oldNormal = red bold
	oldHighlight = red bold 52
	newNormal = green bold
	newHighlight = green bold 22
[credential "https://source.developers.google.com"]
	helper = gcloud.sh
[commit]
	gpgsign = true
[diff "sopsdiffer"]
	textconv = sops -d
[color "diff"]
	meta = 11
	frag = magenta bold
	commit = yellow bold
	old = red bold
	new = green bold
	whitespace = red reverse
