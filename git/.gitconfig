[user]
	name = Kenny Younger
	email = kyounger@gmail.com

[merge]
	tool = Kaleidoscope

[mergetool "splice"]
    cmd = "mvim -f $BASE $LOCAL $REMOTE $MERGED -c 'SpliceInit'"
    trustExitCode = true

[core]
	excludesfile = ~/.gitignore
	hooksPath = /Users/kyounger/.dotfiles/git/git-global-hooks
[color]
	ui = 1

[branch]
        autosetuprebase = always
        autosetupmerge = always
[diff]
	tool = Kaleidoscope
[difftool]
	prompt = false
[mergetool "Kaleidoscope"]
	cmd = ksdiff --merge --output \"$MERGED\" --base \"$BASE\" -- \"$LOCAL\" --snapshot \"$REMOTE\" --snapshot
	trustExitCode = true
[mergetool]
	prompt = false
[hub]
        protocol = https
[push]
	default = current
	followTags = true
[pull]
        rebase = true
[credential]
	helper = osxkeychain
[url "https://"]
	insteadOf = git://
[init]
	templatedir = ~/.dotfiles/git/git-templates
[fetch]
	prune = true
